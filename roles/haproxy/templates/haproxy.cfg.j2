global
    log /dev/log local0
    maxconn 4096
    daemon

defaults
    log     global
    mode    tcp
    option  tcplog
    timeout connect 5s
    timeout client  30s
    timeout server  30s

frontend http
    bind 0.0.0.0:80
    bind :::80
    default_backend traefik_http

frontend https
    bind 0.0.0.0:443
    bind :::443
    default_backend traefik_https

backend traefik_http
    server traefik traefik.hedgehog-wage.ts.net:80 check

backend traefik_https
    server traefik traefik.hedgehog-wage.ts.net:443 check send-proxy-v2

